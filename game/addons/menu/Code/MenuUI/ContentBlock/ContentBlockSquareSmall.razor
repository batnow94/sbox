@using Sandbox;
@using Sandbox.UI;
@using MenuProject.UI;
@inherits Panel

<root class="cblock">
    <ContentBlockHeader Group="@Group"></ContentBlockHeader>
	<ContentBlockBody>
		<ChildContent>
			@foreach ( var package in Group.Packages )
			{
				<PackageCard Package=@package 
							OnLaunch="@( () => ContentBlocks.OnLaunch( package ) )"
							OnMenu="@( () => ContentBlocks.OnMenu( this, package ) )"></PackageCard>
			}
		</ChildContent>
	</ContentBlockBody>
</root>

@code
{
    [Parameter]
    public Package.ListResult.Grouping Group { get; set; }
}
