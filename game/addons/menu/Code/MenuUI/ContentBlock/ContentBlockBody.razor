@using Sandbox;
@using Sandbox.UI;

@inherits Panel

<root>
	<Button class="nav-button left" @ref=ScrollLeft @onclick=@(() => Scroll(true)) Icon="chevron_left"/>
	<div class="content" @ref=ContentParent>
		@ChildContent
	</div>
	<Button class="nav-button right" @ref=ScrollRight @onclick=@(() => Scroll(false)) Icon="chevron_right" />
</root>

@code
{
	private const float ScrollVelocityFactor = 0.2f;

	Panel ContentParent;
	Panel ScrollLeft;
	Panel ScrollRight;


	float ViewportWidth => ContentParent.Box.Rect.Width;
	float ContentWidth => ContentParent.ScrollSize.x;
	float CurrentX => ContentParent.ScrollOffset.x;

	private void Scroll( bool left )
	{
		if ( ContentParent is null ) return;

		var remaining = left ? CurrentX : ContentWidth - CurrentX;
		if ( remaining > 0 )
		{
			float velocity = ViewportWidth / 20;
			ContentParent.ScrollVelocity = new Vector2( left ? -velocity : velocity, 0f );
		}
	}

	public override void Tick()
	{
		base.Tick();

		UpdateVisiblity();
	}

	private void UpdateVisiblity()
	{
		const float margin = 16;

		ScrollLeft.SetClass( "visible", CurrentX > margin && !ContentParent.IsDragScrolling );
		ScrollRight.SetClass( "visible", ContentWidth > ViewportWidth && (ContentWidth - CurrentX) > margin && !ContentParent.IsDragScrolling );
	}
}
